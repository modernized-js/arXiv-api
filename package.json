{
  "name": "@modernized/arxiv-api",
  "version": "1.0.1",
  "description": "node wrapper for arXiv api. typescript version",
  "main": "dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "jest -u ./src/index.test.ts",
    "test:coverage": "jest ./dist/index.test.js --coverage",
    "build": "tsc",
    "format": "prettier --write '{*,src/**/*}.{js,ts}'",
    "lint": "eslint src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/modernized-js/arXiv-api.git"
  },
  "keywords": [
    "arxiv",
    "node",
    "javascript"
  ],
  "author": "elior avraham",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/modernized-js/arXiv-api"
  },
  "homepage": "https://github.com/modernized-js/arXiv-api#readme",
  "dependencies": {
    "fast-xml-parser": "^5.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-node": "11.1.0",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "prettier": "^3.9.5",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "./dist"
  ],
  "directories": {
    "dist": "dist"
  },
  "engines": {
    "node": ">=8.10.0"
  }
}
